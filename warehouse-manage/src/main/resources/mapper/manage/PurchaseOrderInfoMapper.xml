<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lz.manage.mapper.PurchaseOrderInfoMapper">

    <resultMap type="PurchaseOrderInfo" id="PurchaseOrderInfoResult">
        <result property="orderId" column="order_id"/>
        <result property="orderNo" column="order_no"/>
        <result property="supplierId" column="supplier_id"/>
        <result property="orderDate" column="order_date"/>
        <result property="expectedArrivalDate" column="expected_arrival_date"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="orderStatus" column="order_status"/>
        <result property="applicantId" column="applicant_id"/>
        <result property="applicantStatus" column="applicant_status"/>
        <result property="approverId" column="approver_id"/>
        <result property="approvalTime" column="approval_time"/>
        <result property="approvalDesc" column="approval_desc"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <resultMap id="PurchaseOrderInfoPurchaseOrderDetailInfoResult" type="PurchaseOrderInfo"
               extends="PurchaseOrderInfoResult">
        <collection property="purchaseOrderDetailInfoList" ofType="PurchaseOrderDetailInfo" column="order_id"
                    select="selectPurchaseOrderDetailInfoList"/>
    </resultMap>

    <resultMap type="PurchaseOrderDetailInfo" id="PurchaseOrderDetailInfoResult">
        <result property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="partsCode" column="parts_code"/>
        <result property="purchaseQuantity" column="purchase_quantity"/>
        <result property="purchasePrice" column="purchase_price"/>
        <result property="amount" column="amount"/>
        <result property="receivedQuantity" column="received_quantity"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectPurchaseOrderInfoVo">
        select order_id,
               order_no,
               supplier_id,
               order_date,
               expected_arrival_date,
               total_amount,
               order_status,
               applicant_id,
               applicant_status,
               approver_id,
               approval_time,
               approval_desc,
               create_by,
               create_time,
               update_by,
               update_time,
               remark
        from tb_purchase_order_info
    </sql>

    <select id="selectPurchaseOrderInfoList" parameterType="PurchaseOrderInfo" resultMap="PurchaseOrderInfoResult">
        <include refid="selectPurchaseOrderInfoVo"/>
        <where>
            <if test="orderId != null ">and order_id = #{orderId}</if>
            <if test="orderNo != null  and orderNo != ''">and order_no = #{orderNo}</if>
            <if test="supplierId != null ">and supplier_id = #{supplierId}</if>
            <if test="orderStatus != null  and orderStatus != ''">and order_status = #{orderStatus}</if>
            <if test="applicantStatus != null  and applicantStatus != ''">and applicant_status = #{applicantStatus}</if>
            <if test="createBy != null  and createBy != ''">and create_by like concat('%', #{createBy}, '%')</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''">
                and DATE_FORMAT(create_time, '%Y-%m-%d') between #{params.beginCreateTime} and #{params.endCreateTime}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectPurchaseOrderInfoByOrderId" parameterType="Long"
            resultMap="PurchaseOrderInfoPurchaseOrderDetailInfoResult">
        select order_id,
               order_no,
               supplier_id,
               order_date,
               expected_arrival_date,
               total_amount,
               order_status,
               applicant_id,
               applicant_status,
               approver_id,
               approval_time,
               approval_desc,
               create_by,
               create_time,
               update_by,
               update_time,
               remark
        from tb_purchase_order_info
        where order_id = #{orderId}
    </select>

    <select id="selectPurchaseOrderDetailInfoList" resultMap="PurchaseOrderDetailInfoResult">
        select id,
               order_id,
               parts_code,
               purchase_quantity,
               purchase_price,
               amount,
               received_quantity,
               create_by,
               create_time,
               update_by,
               update_time,
               remark
        from tb_purchase_order_detail_info
        where order_id = #{order_id}
    </select>

    <insert id="insertPurchaseOrderInfo" parameterType="PurchaseOrderInfo" useGeneratedKeys="true"
            keyProperty="orderId">
        insert into tb_purchase_order_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="orderDate != null">order_date,</if>
            <if test="expectedArrivalDate != null">expected_arrival_date,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="orderStatus != null and orderStatus != ''">order_status,</if>
            <if test="applicantId != null">applicant_id,</if>
            <if test="applicantStatus != null and applicantStatus != ''">applicant_status,</if>
            <if test="approverId != null">approver_id,</if>
            <if test="approvalTime != null">approval_time,</if>
            <if test="approvalDesc != null">approval_desc,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="supplierId != null">#{supplierId},</if>
            <if test="orderDate != null">#{orderDate},</if>
            <if test="expectedArrivalDate != null">#{expectedArrivalDate},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="orderStatus != null and orderStatus != ''">#{orderStatus},</if>
            <if test="applicantId != null">#{applicantId},</if>
            <if test="applicantStatus != null and applicantStatus != ''">#{applicantStatus},</if>
            <if test="approverId != null">#{approverId},</if>
            <if test="approvalTime != null">#{approvalTime},</if>
            <if test="approvalDesc != null">#{approvalDesc},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePurchaseOrderInfo" parameterType="PurchaseOrderInfo">
        update tb_purchase_order_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="orderDate != null">order_date = #{orderDate},</if>
            <if test="expectedArrivalDate != null">expected_arrival_date = #{expectedArrivalDate},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="orderStatus != null and orderStatus != ''">order_status = #{orderStatus},</if>
            <if test="applicantId != null">applicant_id = #{applicantId},</if>
            <if test="applicantStatus != null and applicantStatus != ''">applicant_status = #{applicantStatus},</if>
            <if test="approverId != null">approver_id = #{approverId},</if>
            <if test="approvalTime != null">approval_time = #{approvalTime},</if>
            <if test="approvalDesc != null">approval_desc = #{approvalDesc},</if>
            <if test="createBy != null and createBy != ''">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where order_id = #{orderId}
    </update>

    <delete id="deletePurchaseOrderInfoByOrderId" parameterType="Long">
        delete
        from tb_purchase_order_info
        where order_id = #{orderId}
    </delete>

    <delete id="deletePurchaseOrderInfoByOrderIds" parameterType="String">
        delete from tb_purchase_order_info where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>

    <delete id="deletePurchaseOrderDetailInfoByOrderIds" parameterType="String">
        delete from tb_purchase_order_detail_info where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>

    <delete id="deletePurchaseOrderDetailInfoByOrderId" parameterType="Long">
        delete
        from tb_purchase_order_detail_info
        where order_id = #{orderId}
    </delete>

    <insert id="batchPurchaseOrderDetailInfo">
        insert into tb_purchase_order_detail_info( id, order_id, parts_code, purchase_quantity, purchase_price, amount,
        received_quantity, create_by, create_time, update_by, update_time, remark) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.orderId}, #{item.partsCode}, #{item.purchaseQuantity}, #{item.purchasePrice},
            #{item.amount}, #{item.receivedQuantity}, #{item.createBy}, #{item.createTime}, #{item.updateBy},
            #{item.updateTime}, #{item.remark})
        </foreach>
    </insert>
</mapper>