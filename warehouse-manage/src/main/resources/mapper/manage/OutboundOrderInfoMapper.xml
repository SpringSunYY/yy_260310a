<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lz.manage.mapper.OutboundOrderInfoMapper">
    
    <resultMap type="OutboundOrderInfo" id="OutboundOrderInfoResult">
        <result property="id"    column="id"    />
        <result property="outboundNo"    column="outbound_no"    />
        <result property="outboundType"    column="outbound_type"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="recipientId"    column="recipient_id"    />
        <result property="recipientDeptId"    column="recipient_dept_id"    />
        <result property="outboundDate"    column="outbound_date"    />
        <result property="outboundStatus"    column="outbound_status"    />
        <result property="isReturnable"    column="is_returnable"    />
        <result property="operatorId"    column="operator_id"    />
        <result property="reviewerId"    column="reviewer_id"    />
        <result property="reviewStatus"    column="review_status"    />
        <result property="reviewTime"    column="review_time"    />
        <result property="reviewRemark"    column="review_remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <resultMap id="OutboundOrderInfoOutboundOrderDetailInfoResult" type="OutboundOrderInfo" extends="OutboundOrderInfoResult">
        <collection property="outboundOrderDetailInfoList" ofType="OutboundOrderDetailInfo" column="id" select="selectOutboundOrderDetailInfoList" />
    </resultMap>

    <resultMap type="OutboundOrderDetailInfo" id="OutboundOrderDetailInfoResult">
        <result property="id"    column="id"    />
        <result property="outboundId"    column="outbound_id"    />
        <result property="partsCode"    column="parts_code"    />
        <result property="outboundQuantity"    column="outbound_quantity"    />
        <result property="batchNo"    column="batch_no"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="locationId"    column="location_id"    />
        <result property="unitPrice"    column="unit_price"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectOutboundOrderInfoVo">
        select id, outbound_no, outbound_type, warehouse_id, recipient_id, recipient_dept_id, outbound_date, outbound_status, is_returnable, operator_id, reviewer_id, review_status, review_time, review_remark, create_by, create_time, update_by, update_time, remark from tb_outbound_order_info
    </sql>

    <select id="selectOutboundOrderInfoList" parameterType="OutboundOrderInfo" resultMap="OutboundOrderInfoResult">
        <include refid="selectOutboundOrderInfoVo"/>
        <where>
            <if test="id != null ">and id = #{id}</if>
            <if test="outboundNo != null  and outboundNo != ''">and outbound_no = #{outboundNo}</if>
            <if test="outboundType != null  and outboundType != ''">and outbound_type = #{outboundType}</if>
            <if test="warehouseId != null">and warehouse_id = #{warehouseId}</if>
            <if test="params.beginOutboundDate != null and params.beginOutboundDate != '' and params.endOutboundDate != null and params.endOutboundDate != ''">
                and DATE_FORMAT(outbound_date, '%Y-%m-%d') between #{params.beginOutboundDate} and
                #{params.endOutboundDate}
            </if>
            <if test="outboundStatus != null  and outboundStatus != ''">and outbound_status = #{outboundStatus}</if>
            <if test="isReturnable != null  and isReturnable != ''">and is_returnable = #{isReturnable}</if>
            <if test="reviewStatus != null  and reviewStatus != ''">and review_status = #{reviewStatus}</if>
            <if test="createBy != null  and createBy != ''">and create_by like concat('%', #{createBy}, '%')</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''">
                and DATE_FORMAT(create_time, '%Y-%m-%d') between #{params.beginCreateTime} and #{params.endCreateTime}
            </if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectOutboundOrderInfoById" parameterType="Long" resultMap="OutboundOrderInfoOutboundOrderDetailInfoResult">
        select id, outbound_no, outbound_type, warehouse_id, recipient_id, recipient_dept_id, outbound_date, outbound_status, is_returnable, operator_id, reviewer_id, review_status, review_time, review_remark, create_by, create_time, update_by, update_time, remark
        from tb_outbound_order_info
        where id = #{id}
    </select>

    <select id="selectOutboundOrderInfoByNo" parameterType="String" resultMap="OutboundOrderInfoResult">
        select id, outbound_no, outbound_type, warehouse_id, recipient_id, recipient_dept_id, outbound_date, outbound_status, is_returnable, operator_id, reviewer_id, review_status, review_time, review_remark, create_by, create_time, update_by, update_time, remark
        from tb_outbound_order_info
        where outbound_no = #{outboundNo}
    </select>

    <select id="selectOutboundOrderDetailInfoList" resultMap="OutboundOrderDetailInfoResult">
        select id, outbound_id, parts_code, outbound_quantity, batch_no, warehouse_id, location_id, unit_price, create_by, create_time, update_by, update_time, remark
        from tb_outbound_order_detail_info
        where outbound_id = #{outbound_id}
    </select>

    <insert id="insertOutboundOrderInfo" parameterType="OutboundOrderInfo" useGeneratedKeys="true" keyProperty="id">
        insert into tb_outbound_order_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="outboundNo != null and outboundNo != ''">outbound_no,</if>
            <if test="outboundType != null and outboundType != ''">outbound_type,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="recipientId != null">recipient_id,</if>
            <if test="recipientDeptId != null">recipient_dept_id,</if>
            <if test="outboundDate != null">outbound_date,</if>
            <if test="outboundStatus != null and outboundStatus != ''">outbound_status,</if>
            <if test="isReturnable != null and isReturnable != ''">is_returnable,</if>
            <if test="operatorId != null">operator_id,</if>
            <if test="reviewerId != null">reviewer_id,</if>
            <if test="reviewStatus != null and reviewStatus != ''">review_status,</if>
            <if test="reviewTime != null">review_time,</if>
            <if test="reviewRemark != null">review_remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="outboundNo != null and outboundNo != ''">#{outboundNo},</if>
            <if test="outboundType != null and outboundType != ''">#{outboundType},</if>
            <if test="warehouseId != null">#{warehouseId},</if>
            <if test="recipientId != null">#{recipientId},</if>
            <if test="recipientDeptId != null">#{recipientDeptId},</if>
            <if test="outboundDate != null">#{outboundDate},</if>
            <if test="outboundStatus != null and outboundStatus != ''">#{outboundStatus},</if>
            <if test="isReturnable != null and isReturnable != ''">#{isReturnable},</if>
            <if test="operatorId != null">#{operatorId},</if>
            <if test="reviewerId != null">#{reviewerId},</if>
            <if test="reviewStatus != null and reviewStatus != ''">#{reviewStatus},</if>
            <if test="reviewTime != null">#{reviewTime},</if>
            <if test="reviewRemark != null">#{reviewRemark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateOutboundOrderInfo" parameterType="OutboundOrderInfo">
        update tb_outbound_order_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="outboundNo != null and outboundNo != ''">outbound_no = #{outboundNo},</if>
            <if test="outboundType != null and outboundType != ''">outbound_type = #{outboundType},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="recipientId != null">recipient_id = #{recipientId},</if>
            <if test="recipientDeptId != null">recipient_dept_id = #{recipientDeptId},</if>
            <if test="outboundDate != null">outbound_date = #{outboundDate},</if>
            <if test="outboundStatus != null and outboundStatus != ''">outbound_status = #{outboundStatus},</if>
            <if test="isReturnable != null and isReturnable != ''">is_returnable = #{isReturnable},</if>
            <if test="operatorId != null">operator_id = #{operatorId},</if>
            <if test="reviewerId != null">reviewer_id = #{reviewerId},</if>
            <if test="reviewStatus != null and reviewStatus != ''">review_status = #{reviewStatus},</if>
            <if test="reviewTime != null">review_time = #{reviewTime},</if>
            <if test="reviewRemark != null">review_remark = #{reviewRemark},</if>
            <if test="createBy != null and createBy != ''">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteOutboundOrderInfoById" parameterType="Long">
        delete from tb_outbound_order_info where id = #{id}
    </delete>

    <delete id="deleteOutboundOrderInfoByIds" parameterType="String">
        delete from tb_outbound_order_info where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <delete id="deleteOutboundOrderDetailInfoByOutboundIds" parameterType="String">
        delete from tb_outbound_order_detail_info where outbound_id in 
        <foreach item="outboundId" collection="array" open="(" separator="," close=")">
            #{outboundId}
        </foreach>
    </delete>

    <delete id="deleteOutboundOrderDetailInfoByOutboundId" parameterType="Long">
        delete from tb_outbound_order_detail_info where outbound_id = #{outboundId}
    </delete>

    <insert id="batchOutboundOrderDetailInfo">
        insert into tb_outbound_order_detail_info( id, outbound_id, parts_code, outbound_quantity, batch_no, warehouse_id, location_id, unit_price, create_by, create_time, update_by, update_time, remark) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.outboundId}, #{item.partsCode}, #{item.outboundQuantity}, #{item.batchNo}, #{item.warehouseId}, #{item.locationId}, #{item.unitPrice}, #{item.createBy}, #{item.createTime}, #{item.updateBy}, #{item.updateTime}, #{item.remark})
        </foreach>
    </insert>
</mapper>