<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lz.manage.mapper.InboundOrderInfoMapper">
    
    <resultMap type="InboundOrderInfo" id="InboundOrderInfoResult">
        <result property="id"    column="id"    />
        <result property="inboundNo"    column="inbound_no"    />
        <result property="inboundType"    column="inbound_type"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="orderId"    column="order_id"    />
        <result property="supplierId"    column="supplier_id"    />
        <result property="inboundDate"    column="inbound_date"    />
        <result property="inboundStatus"    column="inbound_status"    />
        <result property="operatorId"    column="operator_id"    />
        <result property="reviewerId"    column="reviewer_id"    />
        <result property="reviewStatus"    column="review_status"    />
        <result property="reviewTime"    column="review_time"    />
        <result property="reviewRemark"    column="review_remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <resultMap id="InboundOrderInfoInboundOrderDetailInfoResult" type="InboundOrderInfo" extends="InboundOrderInfoResult">
        <collection property="inboundOrderDetailInfoList" ofType="InboundOrderDetailInfo" column="id" select="selectInboundOrderDetailInfoList" />
    </resultMap>

    <resultMap type="InboundOrderDetailInfo" id="InboundOrderDetailInfoResult">
        <result property="id"    column="id"    />
        <result property="inboundId"    column="inbound_id"    />
        <result property="partsCode"    column="parts_code"    />
        <result property="inboundQuantity"    column="inbound_quantity"    />
        <result property="batchNo"    column="batch_no"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="locationId"    column="location_id"    />
        <result property="qualityStatus"    column="quality_status"    />
        <result property="productionDate"    column="production_date"    />
        <result property="expiryDate"    column="expiry_date"    />
        <result property="unitPrice"    column="unit_price"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectInboundOrderInfoVo">
        select id, inbound_no, inbound_type, warehouse_id, order_id, supplier_id, inbound_date, inbound_status, operator_id, reviewer_id, review_status, review_time, review_remark, create_by, create_time, update_by, update_time, remark from tb_inbound_order_info
    </sql>

    <select id="selectInboundOrderInfoList" parameterType="InboundOrderInfo" resultMap="InboundOrderInfoResult">
        <include refid="selectInboundOrderInfoVo"/>
        <where>  
            <if test="id != null "> and id = #{id}</if>
            <if test="inboundNo != null  and inboundNo != ''"> and inbound_no = #{inboundNo}</if>
            <if test="inboundType != null  and inboundType != ''"> and inbound_type = #{inboundType}</if>
            <if test="warehouseId != null "> and warehouse_id = #{warehouseId}</if>
            <if test="orderId != null "> and order_id = #{orderId}</if>
            <if test="supplierId != null "> and supplier_id = #{supplierId}</if>
            <if test="inboundDate != null "> and inbound_date = #{inboundDate}</if>
            <if test="inboundStatus != null  and inboundStatus != ''"> and inbound_status = #{inboundStatus}</if>
            <if test="reviewStatus != null  and reviewStatus != ''"> and review_status = #{reviewStatus}</if>
            <if test="createBy != null  and createBy != ''"> and create_by like concat('%', #{createBy}, '%')</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and DATE_FORMAT(create_time, '%Y-%m-%d') between #{params.beginCreateTime} and #{params.endCreateTime}</if>
        </where>
    </select>
    
    <select id="selectInboundOrderInfoById" parameterType="Long" resultMap="InboundOrderInfoInboundOrderDetailInfoResult">
        select id, inbound_no, inbound_type, warehouse_id, order_id, supplier_id, inbound_date, inbound_status, operator_id, reviewer_id, review_status, review_time, review_remark, create_by, create_time, update_by, update_time, remark
        from tb_inbound_order_info
        where id = #{id}
    </select>

    <select id="selectInboundOrderInfoByNo" parameterType="String" resultMap="InboundOrderInfoResult">
        select id, inbound_no, inbound_type, warehouse_id, order_id, supplier_id, inbound_date, inbound_status, operator_id, reviewer_id, review_status, review_time, review_remark, create_by, create_time, update_by, update_time, remark
        from tb_inbound_order_info
        where inbound_no = #{inboundNo}
    </select>

    <select id="selectInboundOrderDetailInfoList" resultMap="InboundOrderDetailInfoResult">
        select id, inbound_id, parts_code, inbound_quantity, batch_no, warehouse_id, location_id, quality_status, production_date, expiry_date, unit_price, create_by, create_time, update_by, update_time, remark
        from tb_inbound_order_detail_info
        where inbound_id = #{inbound_id}
    </select>

    <insert id="insertInboundOrderInfo" parameterType="InboundOrderInfo" useGeneratedKeys="true" keyProperty="id">
        insert into tb_inbound_order_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="inboundNo != null and inboundNo != ''">inbound_no,</if>
            <if test="inboundType != null and inboundType != ''">inbound_type,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="orderId != null">order_id,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="inboundDate != null">inbound_date,</if>
            <if test="inboundStatus != null and inboundStatus != ''">inbound_status,</if>
            <if test="operatorId != null">operator_id,</if>
            <if test="reviewerId != null">reviewer_id,</if>
            <if test="reviewStatus != null and reviewStatus != ''">review_status,</if>
            <if test="reviewTime != null">review_time,</if>
            <if test="reviewRemark != null">review_remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="inboundNo != null and inboundNo != ''">#{inboundNo},</if>
            <if test="inboundType != null and inboundType != ''">#{inboundType},</if>
            <if test="warehouseId != null">#{warehouseId},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="supplierId != null">#{supplierId},</if>
            <if test="inboundDate != null">#{inboundDate},</if>
            <if test="inboundStatus != null and inboundStatus != ''">#{inboundStatus},</if>
            <if test="operatorId != null">#{operatorId},</if>
            <if test="reviewerId != null">#{reviewerId},</if>
            <if test="reviewStatus != null and reviewStatus != ''">#{reviewStatus},</if>
            <if test="reviewTime != null">#{reviewTime},</if>
            <if test="reviewRemark != null">#{reviewRemark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateInboundOrderInfo" parameterType="InboundOrderInfo">
        update tb_inbound_order_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="inboundNo != null and inboundNo != ''">inbound_no = #{inboundNo},</if>
            <if test="inboundType != null and inboundType != ''">inbound_type = #{inboundType},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="orderId != null">order_id = #{orderId},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="inboundDate != null">inbound_date = #{inboundDate},</if>
            <if test="inboundStatus != null and inboundStatus != ''">inbound_status = #{inboundStatus},</if>
            <if test="operatorId != null">operator_id = #{operatorId},</if>
            <if test="reviewerId != null">reviewer_id = #{reviewerId},</if>
            <if test="reviewStatus != null and reviewStatus != ''">review_status = #{reviewStatus},</if>
            <if test="reviewTime != null">review_time = #{reviewTime},</if>
            <if test="reviewRemark != null">review_remark = #{reviewRemark},</if>
            <if test="createBy != null and createBy != ''">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteInboundOrderInfoById" parameterType="Long">
        delete from tb_inbound_order_info where id = #{id}
    </delete>

    <delete id="deleteInboundOrderInfoByIds" parameterType="String">
        delete from tb_inbound_order_info where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <delete id="deleteInboundOrderDetailInfoByInboundIds" parameterType="String">
        delete from tb_inbound_order_detail_info where inbound_id in 
        <foreach item="inboundId" collection="array" open="(" separator="," close=")">
            #{inboundId}
        </foreach>
    </delete>

    <delete id="deleteInboundOrderDetailInfoByInboundId" parameterType="Long">
        delete from tb_inbound_order_detail_info where inbound_id = #{inboundId}
    </delete>

    <insert id="batchInboundOrderDetailInfo">
        insert into tb_inbound_order_detail_info( id, inbound_id, parts_code, inbound_quantity, batch_no, warehouse_id, location_id, quality_status, production_date, expiry_date, unit_price, create_by, create_time, update_by, update_time, remark) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.inboundId}, #{item.partsCode}, #{item.inboundQuantity}, #{item.batchNo}, #{item.warehouseId}, #{item.locationId}, #{item.qualityStatus}, #{item.productionDate}, #{item.expiryDate}, #{item.unitPrice}, #{item.createBy}, #{item.createTime}, #{item.updateBy}, #{item.updateTime}, #{item.remark})
        </foreach>
    </insert>
</mapper>