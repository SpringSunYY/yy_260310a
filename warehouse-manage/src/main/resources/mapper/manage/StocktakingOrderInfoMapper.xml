<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lz.manage.mapper.StocktakingOrderInfoMapper">
    
    <resultMap type="StocktakingOrderInfo" id="StocktakingOrderInfoResult">
        <result property="id"    column="id"    />
        <result property="stocktakingNo"    column="stocktaking_no"    />
        <result property="stocktakingType"    column="stocktaking_type"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="startDate"    column="start_date"    />
        <result property="endDate"    column="end_date"    />
        <result property="stocktakingStatus"    column="stocktaking_status"    />
        <result property="operatorId"    column="operator_id"    />
        <result property="reviewerId"    column="reviewer_id"    />
        <result property="reviewStatus"    column="review_status"    />
        <result property="reviewTime"    column="review_time"    />
        <result property="reviewRemark"    column="review_remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <resultMap id="StocktakingOrderInfoStocktakingOrderDetailInfoResult" type="StocktakingOrderInfo" extends="StocktakingOrderInfoResult">
        <collection property="stocktakingOrderDetailInfoList" ofType="StocktakingOrderDetailInfo" column="id" select="selectStocktakingOrderDetailInfoList" />
    </resultMap>

    <resultMap type="StocktakingOrderDetailInfo" id="StocktakingOrderDetailInfoResult">
        <result property="id"    column="id"    />
        <result property="stocktakingId"    column="stocktaking_id"    />
        <result property="partsCode"    column="parts_code"    />
        <result property="warehouseId"    column="warehouse_id"    />
        <result property="locationId"    column="location_id"    />
        <result property="batchNo"    column="batch_no"    />
        <result property="bookQuantity"    column="book_quantity"    />
        <result property="actualQuantity"    column="actual_quantity"    />
        <result property="differenceQuantity"    column="difference_quantity"    />
        <result property="differenceReason"    column="difference_reason"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectStocktakingOrderInfoVo">
        select id, stocktaking_no, stocktaking_type, warehouse_id, start_date, end_date, stocktaking_status, operator_id, reviewer_id, review_status, review_time, review_remark, create_by, create_time, update_by, update_time, remark from tb_stocktaking_order_info
    </sql>

    <select id="selectStocktakingOrderInfoList" parameterType="StocktakingOrderInfo" resultMap="StocktakingOrderInfoResult">
        <include refid="selectStocktakingOrderInfoVo"/>
        <where>  
            <if test="id != null "> and id = #{id}</if>
            <if test="stocktakingNo != null  and stocktakingNo != ''"> and stocktaking_no = #{stocktakingNo}</if>
            <if test="stocktakingType != null  and stocktakingType != ''"> and stocktaking_type = #{stocktakingType}</if>
            <if test="warehouseId != null "> and warehouse_id = #{warehouseId}</if>
            <if test="stocktakingStatus != null  and stocktakingStatus != ''"> and stocktaking_status = #{stocktakingStatus}</if>
            <if test="reviewStatus != null  and reviewStatus != ''"> and review_status = #{reviewStatus}</if>
            <if test="createBy != null  and createBy != ''"> and create_by like concat('%', #{createBy}, '%')</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != '' and params.endCreateTime != null and params.endCreateTime != ''"> and DATE_FORMAT(create_time, '%Y-%m-%d') between #{params.beginCreateTime} and #{params.endCreateTime}</if>
        </where>
    </select>
    
    <select id="selectStocktakingOrderInfoById" parameterType="Long" resultMap="StocktakingOrderInfoStocktakingOrderDetailInfoResult">
        select id, stocktaking_no, stocktaking_type, warehouse_id, start_date, end_date, stocktaking_status, operator_id, reviewer_id, review_status, review_time, review_remark, create_by, create_time, update_by, update_time, remark
        from tb_stocktaking_order_info
        where id = #{id}
    </select>

    <select id="selectStocktakingOrderDetailInfoList" resultMap="StocktakingOrderDetailInfoResult">
        select id, stocktaking_id, parts_code, warehouse_id, location_id, batch_no, book_quantity, actual_quantity, difference_quantity, difference_reason, create_by, create_time, update_by, update_time, remark
        from tb_stocktaking_order_detail_info
        where stocktaking_id = #{stocktaking_id}
    </select>

    <insert id="insertStocktakingOrderInfo" parameterType="StocktakingOrderInfo" useGeneratedKeys="true" keyProperty="id">
        insert into tb_stocktaking_order_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="stocktakingNo != null and stocktakingNo != ''">stocktaking_no,</if>
            <if test="stocktakingType != null and stocktakingType != ''">stocktaking_type,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="startDate != null">start_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="stocktakingStatus != null and stocktakingStatus != ''">stocktaking_status,</if>
            <if test="operatorId != null">operator_id,</if>
            <if test="reviewerId != null">reviewer_id,</if>
            <if test="reviewStatus != null and reviewStatus != ''">review_status,</if>
            <if test="reviewTime != null">review_time,</if>
            <if test="reviewRemark != null">review_remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="stocktakingNo != null and stocktakingNo != ''">#{stocktakingNo},</if>
            <if test="stocktakingType != null and stocktakingType != ''">#{stocktakingType},</if>
            <if test="warehouseId != null">#{warehouseId},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="stocktakingStatus != null and stocktakingStatus != ''">#{stocktakingStatus},</if>
            <if test="operatorId != null">#{operatorId},</if>
            <if test="reviewerId != null">#{reviewerId},</if>
            <if test="reviewStatus != null and reviewStatus != ''">#{reviewStatus},</if>
            <if test="reviewTime != null">#{reviewTime},</if>
            <if test="reviewRemark != null">#{reviewRemark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateStocktakingOrderInfo" parameterType="StocktakingOrderInfo">
        update tb_stocktaking_order_info
        <trim prefix="SET" suffixOverrides=",">
            <if test="stocktakingNo != null and stocktakingNo != ''">stocktaking_no = #{stocktakingNo},</if>
            <if test="stocktakingType != null and stocktakingType != ''">stocktaking_type = #{stocktakingType},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="stocktakingStatus != null and stocktakingStatus != ''">stocktaking_status = #{stocktakingStatus},</if>
            <if test="operatorId != null">operator_id = #{operatorId},</if>
            <if test="reviewerId != null">reviewer_id = #{reviewerId},</if>
            <if test="reviewStatus != null and reviewStatus != ''">review_status = #{reviewStatus},</if>
            <if test="reviewTime != null">review_time = #{reviewTime},</if>
            <if test="reviewRemark != null">review_remark = #{reviewRemark},</if>
            <if test="createBy != null and createBy != ''">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteStocktakingOrderInfoById" parameterType="Long">
        delete from tb_stocktaking_order_info where id = #{id}
    </delete>

    <delete id="deleteStocktakingOrderInfoByIds" parameterType="String">
        delete from tb_stocktaking_order_info where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <delete id="deleteStocktakingOrderDetailInfoByStocktakingIds" parameterType="String">
        delete from tb_stocktaking_order_detail_info where stocktaking_id in 
        <foreach item="stocktakingId" collection="array" open="(" separator="," close=")">
            #{stocktakingId}
        </foreach>
    </delete>

    <delete id="deleteStocktakingOrderDetailInfoByStocktakingId" parameterType="Long">
        delete from tb_stocktaking_order_detail_info where stocktaking_id = #{stocktakingId}
    </delete>

    <insert id="batchStocktakingOrderDetailInfo">
        insert into tb_stocktaking_order_detail_info( id, stocktaking_id, parts_code, warehouse_id, location_id, batch_no, book_quantity, actual_quantity, difference_quantity, difference_reason, create_by, create_time, update_by, update_time, remark) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.stocktakingId}, #{item.partsCode}, #{item.warehouseId}, #{item.locationId}, #{item.batchNo}, #{item.bookQuantity}, #{item.actualQuantity}, #{item.differenceQuantity}, #{item.differenceReason}, #{item.createBy}, #{item.createTime}, #{item.updateBy}, #{item.updateTime}, #{item.remark})
        </foreach>
    </insert>
</mapper>